{
  "name": "junk-drawer",
  "version": "1.1.11",
  "description": "Every annoying file tool in one place.",
  "author": "Abhay Shah",
  "license": "MIT",
  "repository": "github:AbhayShah06/JunkDrawer",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "vendor": "node scripts/vendor.mjs",
    "dist:mac": "npm run vendor && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --universal",
    "release:mac": "npm run vendor && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --universal --publish always",
    "dist:win": "npm run vendor && electron-builder --win nsis",
    "fetch-bins:win": "node scripts/fetch-bins-win.mjs"
  },
  "devDependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/core-mt": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "@imgly/background-removal": "^1.4.5",
    "@imgly/background-removal-data": "^1.4.5",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "fflate": "^0.8.2",
    "heic2any": "^0.0.4",
    "js-yaml": "^4.1.0",
    "jsqr": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.0.379",
    "qrcode": "^1.5.3"
  },
  "build": {
    "appId": "vc.axl.junkdrawer",
    "productName": "Junk Drawer",
    "fileAssociations": [
      { "ext": "pdf", "name": "PDF Document", "role": "Viewer" },
      { "ext": "md", "name": "Markdown Document", "role": "Viewer" },
      { "ext": "markdown", "name": "Markdown Document", "role": "Viewer" },
      { "ext": "txt", "name": "Text Document", "role": "Viewer" }
    ],
    "files": [
      "index.html",
      "electron/**/*",
      "vendor/**/*",
      "icon.ico",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities",
      "x64ArchFiles": "**/bin/*",
      "extraResources": [
        {
          "from": "resources/bin/mac",
          "to": "bin",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis"
      ],
      "extraResources": [
        {
          "from": "resources/bin/win",
          "to": "bin",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "Junk Drawer ${version}",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AbhayShah06",
        "repo": "JunkDrawer",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist-app"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
